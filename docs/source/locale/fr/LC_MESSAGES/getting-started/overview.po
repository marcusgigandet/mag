#~ "From that import, MAG re-exports "
#~ "its core vector, matrix, constants, and"
#~ " concepts modules. When SIMD is "
#~ "enabled for the target platform, the "
#~ "public SIMD module is exported too."
#~ msgstr ""

#~ msgid "Core functionality"
#~ msgstr ""

#~ msgid "MAG currently provides:"
#~ msgstr ""

#~ msgid ""
#~ "**Vectors** for 2D, 3D, and 4D "
#~ "math, including arithmetic, normalization, dot"
#~ " products, clamping, interpolation, and "
#~ "comparisons."
#~ msgstr ""

#~ msgid ""
#~ "**Matrices** for 3x3 and 4x4 math, "
#~ "including arithmetic, transpose, inverse, "
#~ "identity, translation, rotation, and diagonal"
#~ " constructors."
#~ msgstr ""

#~ msgid ""
#~ "**Constants and helpers** used in "
#~ "graphics-heavy code, such as ``pi<T>``."
#~ msgstr ""

#~ msgid ""
#~ "**SIMD support** for native and "
#~ "fixed-width vector operations on supported"
#~ " platforms."
#~ msgstr ""

#~ msgid "Public module layout"
#~ msgstr ""

#~ msgid "The ``mag`` module re-exports the following public areas:"
#~ msgstr ""

#~ msgid "aliases"
#~ msgstr ""

#~ msgid "concepts"
#~ msgstr ""

#~ msgid "constants"
#~ msgstr ""

#~ msgid "matrix, matrix_3x3, matrix_4x4, matrix_ops"
#~ msgstr ""

#~ msgid "vector, vector_2, vector_3, vector_4, vector_ops"
#~ msgstr ""

#~ msgid "simd (only when ``MAG_ENABLE_SIMD`` is enabled)"
#~ msgstr ""

